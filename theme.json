{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"customTemplates": [
		{
			"name": "book-review",
			"postTypes": [
				"post"
			],
			"title": "Book Review"
		},
		{
			"name": "theme-showcase",
			"postTypes": [
				"post"
			],
			"title": "Theme Showcase"
		},
		{
			"name": "page-full-width",
			"postTypes": [
				"page"
			],
			"title": "Page (Full Width)"
		}
	],
	"settings": {
		"appearanceTools": true,
		"blocks": {
			"core/image": {
				"lightbox": {
					"allowEditing": true,
					"enabled": true
				}
			}
		},
		"color": {
			"defaultDuotone": false,
			"duotone": [
				{
					"colors": [
						"#211A12",
						"#FAFAFA"
					],
					"name": "Default",
					"slug": "duotone-default"
				},
				{
					"colors": [
						"#211A12",
						"#ff4a1a"
					],
					"name": "Duo Orange",
					"slug": "duo-orange"
				},
				{
					"colors": [
						"#211A12",
						"#FFDD33"
					],
					"name": "Duo Yellow",
					"slug": "duo-yellow"
				},
				{
					"colors": [
						"#211A12",
						"#FF4AB5"
					],
					"name": "Duo Pink",
					"slug": "duo-pink"
				},
				{
					"colors": [
						"#211A12",
						"#4DB6FF"
					],
					"name": "Duo Blue",
					"slug": "duo-blue"
				}
			],
			"gradients": [
				{
					"gradient": "linear-gradient(to bottom,var(--wp--preset--color--base) 48%,var(--wp--preset--color--primary) 48%)",
					"name": "Gradient Default",
					"slug": "gradient-default"
				}
			],
			"palette": [
				{
					"color": "#fafafa",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#ff4a1a",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#2a2622",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#2a2622",
					"name": "Secondary",
					"slug": "secondary"
				},
				{
					"color": "#2a26221a",
					"name": "Tertiary",
					"slug": "tertiary"
				},
				{
					"color": "#f2f3f4",
					"name": "Quaternary",
					"slug": "quaternary"
				}
			],
			"text": true
		},
		"layout": {
			"contentSize": "700px",
			"wideSize": "1300px"
		},
		"spacing": {
			"customSpacingSize": true,
			"defaultSpacingSizes": false,
			"spacingScale": {
				"theme": {
					"steps": 0
				}
			},
			"spacingSizes": [
				{
					"name": "2X-Small",
					"size": "0.5rem",
					"slug": "20"
				},
				{
					"name": "X-Small",
					"size": "clamp(0.5rem, 1vw, 1rem)",
					"slug": "30"
				},
				{
					"name": "Small",
					"size": "clamp(0.75rem, 1.5vw, 1.5rem)",
					"slug": "40"
				},
				{
					"name": "Medium",
					"size": "clamp(1rem, 2vw, 2rem)",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "clamp(1.5rem, 3vw, 3rem)",
					"slug": "60"
				},
				{
					"name": "X-Large",
					"size": "clamp(2rem, 4vw, 4rem)",
					"slug": "70"
				},
				{
					"name": "2X-Large",
					"size": "clamp(3rem, 6vw, 6rem)",
					"slug": "80"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"customFontSize": true,
			"defaultFontSizes": false,
			"dropCap": true,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Neue Montreal",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/neue-montreal/neue-montreal-400-normal.woff2"
							]
						},
						{
							"fontFamily": "Neue Montreal",
							"fontStyle": "italic",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/neue-montreal/neue-montreal-400-italic.woff2"
							]
						},
						{
							"fontFamily": "Neue Montreal",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/neue-montreal/neue-montreal-700-normal.woff2"
							]
						},
						{
							"fontFamily": "Neue Montreal",
							"fontStyle": "italic",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/neue-montreal/neue-montreal-700-italic.woff2"
							]
						}
					],
					"fontFamily": "Neue Montreal, sans-serif",
					"name": "Neue Montreal",
					"slug": "neue-montreal"
				},
				{
					"fontFace": [
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/manrope/manrope-400-normal.woff2"
							]
						},
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/manrope/manrope-500-normal.woff2"
							]
						},
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/manrope/manrope-600-normal.woff2"
							]
						},
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/manrope/manrope-700-normal.woff2"
							]
						}
					],
					"fontFamily": "Manrope, sans-serif",
					"name": "Manrope",
					"slug": "manrope"
				}
			],
			"fontSizes": [
				{
					"fluid": {
						"max": "0.76rem",
						"min": "0.72rem"
					},
					"name": "Extra Small",
					"size": "0.76rem",
					"slug": "x-small"
				},
				{
					"fluid": {
						"max": "1.125rem",
						"min": "1rem"
					},
					"name": "Small",
					"size": "1.125rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1.5rem",
						"min": "1rem"
					},
					"name": "Medium",
					"size": "1.5rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.75rem",
						"min": "1.5rem"
					},
					"name": "Large",
					"size": "1.75rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "3rem",
						"min": "2rem"
					},
					"name": "Extra Large",
					"size": "3rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "4.5rem",
						"min": "3rem"
					},
					"name": "Display",
					"size": "4.5rem",
					"slug": "display"
				}
			],
			"fontStyle": true,
			"fontWeight": true,
			"letterSpacing": true,
			"textDecoration": true,
			"textTransform": true
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/avatar": {
				"border": {
					"radius": "2px"
				},
				"filter": {
					"duotone": "var(--wp--preset--duotone--duo-orange)"
				}
			},
			"core/button": {
				"border": {
					"bottom": {
						"color": "var(--wp--preset--color--primary)",
						"style": "solid",
						"width": "2px"
					},
					"left": {
						"color": "var(--wp--preset--color--primary)",
						"style": "solid",
						"width": "2px"
					},
					"right": {
						"color": "var(--wp--preset--color--primary)",
						"style": "solid",
						"width": "2px"
					},
					"top": {
						"color": "var(--wp--preset--color--primary)",
						"style": "solid",
						"width": "2px"
					}
				},
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--contrast)"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--contrast)"
						}
					}
				},
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--30)",
						"left": "var(--wp--preset--spacing--40)",
						"right": "var(--wp--preset--spacing--40)",
						"top": "var(--wp--preset--spacing--30)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"fontStyle": "normal",
					"fontWeight": "600",
					"letterSpacing": "0.02rem",
					"textTransform": "uppercase"
				},
				"variations": {
					"outline": {
						"border": {
							"bottom": {
								"color": "var(--wp--preset--color--primary)",
								"style": "solid",
								"width": "2px"
							},
							"left": {
								"color": "var(--wp--preset--color--primary)",
								"style": "solid",
								"width": "2px"
							},
							"right": {
								"color": "var(--wp--preset--color--primary)",
								"style": "solid",
								"width": "2px"
							},
							"top": {
								"color": "var(--wp--preset--color--primary)",
								"style": "solid",
								"width": "2px"
							}
						},
						"color": {
							"background": "var(--wp--preset--color--base)",
							"text": "var(--wp--preset--color--primary)"
						},
						"spacing": {
							"padding": {
								"bottom": "var(--wp--preset--spacing--30)",
								"left": "var(--wp--preset--spacing--40)",
								"right": "var(--wp--preset--spacing--40)",
								"top": "var(--wp--preset--spacing--30)"
							}
						},
						"typography": {
							"fontSize": "var(--wp--preset--font-size--x-small)",
							"letterSpacing": "0.02rem",
							"textTransform": "none"
						}
					}
				},
				"css": "&.is-style-outline > .wp-block-button__link:not(.has-background):hover{background-color:var(--wp--preset--color--secondary);color:var(--wp--preset--color--base);border-color:var(--wp--preset--color--secondary)}"
			},
			"core/buttons": {
				"spacing": {
					"blockGap": {
						"left": "var(--wp--preset--spacing--20)"
					}
				}
			},
			"core/code": {
				"border": {
					"color": "var(--wp--preset--color--contrast)",
					"radius": "0.25rem",
					"style": "solid",
					"width": "2px"
				},
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--50)",
						"left": "var(--wp--preset--spacing--50)",
						"right": "var(--wp--preset--spacing--50)",
						"top": "var(--wp--preset--spacing--50)"
					}
				},
				"typography": {
					"fontFamily": "monospace"
				}
			},
			"core/columns": {
				"spacing": {
					"blockGap": {
						"top": "var(--wp--preset--spacing--40)"
					}
				}
			},
			"core/comment-author-name": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"fontStyle": "normal",
					"fontWeight": "700"
				}
			},
			"core/comment-content": {
				"spacing": {
					"padding": {
						"bottom": "0px",
						"top": "0px"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/comment-date": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"letterSpacing": "0.02rem",
					"textDecoration": "none",
					"textTransform": "none"
				}
			},
			"core/comment-edit-link": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"letterSpacing": "0.02rem",
					"textTransform": "uppercase"
				}
			},
			"core/comment-reply-link": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"fontStyle": "normal",
					"fontWeight": "700",
					"letterSpacing": "0.02rem",
					"textTransform": "uppercase"
				}
			},
			"core/comments-pagination": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontStyle": "normal",
					"fontWeight": "600"
				}
			},
			"core/comments-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontStyle": "normal",
					"fontWeight": "600"
				}
			},
			"core/cover": {
				"filter": {
					"duotone": "var(--wp--preset--duotone--duo-orange)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)"
				},
				"css": "overflow:hidden;& .wp-block-cover__image-background{transition:filter 0.35s cubic-bezier(.4,0,.2,1),transform 0.6s cubic-bezier(.4,0,.2,1)} &:hover .wp-block-cover__image-background{filter:none !important;transform:scale(1.04)} &:hover{filter:none !important}"
			},
			"core/footnotes": {
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--30)",
						"right": "0px",
						"top": "var(--wp--preset--spacing--40)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/gallery": {
				"spacing": {
					"margin": {
						"bottom": "var(--wp--preset--spacing--50)"
					}
				}
			},
			"core/image": {
				"border": {
					"radius": "0px"
				}
			},
			"core/list": {
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--70)"
					}
				}
			},
			"core/navigation": {
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"spacing": {
					"blockGap": "0"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontStyle": "normal",
					"fontWeight": "600",
					"letterSpacing": "0.02rem",
					"lineHeight": "1.5",
					"textTransform": "none"
				}
			},
			"core/post-author": {
				"filter": {
					"duotone": "var(--wp--preset--duotone--default)"
				},
				"spacing": {
					"padding": {
						"bottom": "0px",
						"top": "0px"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-author-name": {
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/post-comments-form": {
				"spacing": {
					"margin": {
						"bottom": "var(--wp--preset--spacing--50)",
						"top": "var(--wp--preset--spacing--80)"
					}
				}
			},
			"core/post-content": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--40)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"letterSpacing": "0rem",
					"lineHeight": 1.6
				}
			},
			"core/post-date": {
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--manrope)",
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"fontStyle": "normal",
					"fontWeight": "600",
					"letterSpacing": "0.01rem",
					"textTransform": "none"
				}
			},
			"core/post-excerpt": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"letterSpacing": "0.02rem"
				}
			},
			"core/post-featured-image": {
				"border": {
					"radius": "2px"
				},
				"filter": {
					"duotone": "var(--wp--preset--duotone--duotone-default)"
				},
				"spacing": {
					"padding": {
						"bottom": "0px",
						"top": "0px"
					}
				},
				"css": "overflow:hidden;& img{transition:filter 0.35s cubic-bezier(.4,0,.2,1),transform 0.6s cubic-bezier(.4,0,.2,1)} &:hover img{filter:none !important;transform:scale(1.04)} &:hover{filter:none !important}"
			},
			"core/post-navigation-link": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"fontStyle": "normal",
					"fontWeight": "600",
					"letterSpacing": "0.02rem"
				}
			},
			"core/post-terms": {
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"fontStyle": "normal",
					"fontWeight": "400",
					"letterSpacing": "0.02rem",
					"textDecoration": "underline",
					"textTransform": "none"
				}
			},
			"core/post-time-to-read": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"fontStyle": "normal",
					"fontWeight": "600",
					"letterSpacing": "0.01rem",
					"textTransform": "uppercase"
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"spacing": {
					"margin": {
						"bottom": "0px"
					}
				}
			},
			"core/pullquote": {
				"border": {
					"bottom": {
						"color": "var(--wp--preset--color--tertiary)",
						"style": "dotted",
						"width": "1px 0"
					},
					"color": null,
					"left": {
						"style": "none",
						"width": "0px"
					},
					"right": {
						"style": "none",
						"width": "0px"
					},
					"style": null,
					"top": {
						"color": "var(--wp--preset--color--tertiary)",
						"style": "dotted",
						"width": "1px"
					},
					"width": null
				},
				"spacing": {
					"margin": {
						"bottom": "var(--wp--preset--spacing--40)",
						"top": "0px"
					},
					"padding": {
						"bottom": "var(--wp--preset--spacing--60)",
						"left": "var(--wp--preset--spacing--40)",
						"right": "var(--wp--preset--spacing--40)",
						"top": "var(--wp--preset--spacing--60)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontStyle": "normal",
					"fontWeight": "300",
					"lineHeight": "1.5"
				}
			},
			"core/query-pagination": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontStyle": "normal",
					"fontWeight": "600",
					"letterSpacing": "0rem"
				}
			},
			"core/query-title": {
				"spacing": {
					"margin": {
						"bottom": "0px",
						"top": "0px"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)",
